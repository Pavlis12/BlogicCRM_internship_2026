@model BlogicCRM.Models.Client
@{
    ViewData["Title"] = "Smazat klienta";
}

<h1>Smazat klienta</h1>
<h3 class="text-danger">Opravdu chcete tohoto klienta smazat?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Jméno a Příjmení</dt>
        <dd class="col-sm-10">@Model.Jmeno @Model.Prijmeni</dd>
    </dl>
    
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Smazat navždy" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary ms-2">Zpět na seznam</a>
    </form>
</div>