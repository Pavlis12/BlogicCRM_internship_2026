@{
    ViewData["Title"] = "Hlavní panel";
}

<div class="text-center mt-4">
    <h1 class="display-4 fw-bold">Vítejte v BlogicCRM</h1>
    <p class="lead text-muted">Jednoduchý a efektivní systém pro správu klientů, poradců a smluv.</p>
</div>

<div class="row text-center mt-5">
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0 bg-light">
            <div class="card-body p-4">
                <i class="bi bi-people-fill text-primary" style="font-size: 4rem;"></i>
                <h3 class="card-title mt-3">Klienti</h3>
                <p class="card-text text-muted">Evidence osobních údajů a kontaktních informací všech klientů.</p>
                <a asp-controller="Clients" asp-action="Index" class="btn btn-primary w-100 mt-2">Spravovat klienty</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0 bg-light">
            <div class="card-body p-4">
                <i class="bi bi-person-badge-fill text-success" style="font-size: 4rem;"></i>
                <h3 class="card-title mt-3">Poradci</h3>
                <p class="card-text text-muted">Seznam všech finančních poradců a jejich detailů.</p>
                <a asp-controller="Advisors" asp-action="Index" class="btn btn-success w-100 mt-2">Spravovat poradce</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 border-0 bg-light">
            <div class="card-body p-4">
                <i class="bi bi-file-earmark-text-fill text-danger" style="font-size: 4rem;"></i>
                <h3 class="card-title mt-3">Smlouvy</h3>
                <p class="card-text text-muted">Propojování klientů a poradců, správa finančních produktů.</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-danger w-100 mt-2">Spravovat smlouvy</a>
            </div>
        </div>
    </div>
</div>